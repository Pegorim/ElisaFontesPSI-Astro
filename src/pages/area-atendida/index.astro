---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { bairros, regioes, getBairrosByRegiao } from '../../data/bairros';

const pageSchema = {
  "@context": "https://schema.org",
  "@type": ["Psychologist", "LocalBusiness"],
  "name": "Elisa Fontes - Psicóloga em Niterói",
  "description": "Psicóloga clínica com 38 anos de experiência. Atendimento presencial em São Francisco, Niterói, e online para todo o Brasil.",
  "url": "https://elisafontes.com.br/area-atendida",
  "telephone": "+55-21-98744-9887",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Rua Rui Barbosa, 29 - Sala 213",
    "addressLocality": "São Francisco",
    "addressRegion": "Niterói, RJ",
    "postalCode": "24360-400",
    "addressCountry": "BR"
  },
  "areaServed": bairros.map((b) => ({ "@type": "Place", "name": `${b.name}, Niterói` }))
};
---

<Layout
  title="Psicóloga em Niterói por Bairro | Elisa Fontes"
  description="Elisa Fontes atende pacientes de todos os bairros de Niterói. Consultório presencial em São Francisco e atendimento online para todo o Brasil."
  schema={pageSchema}
>
  <Header />

  <main class="bg-primary-bg">

    <!-- Hero -->
    <section class="py-16 md:py-20 px-6 md:px-12 lg:px-20 bg-card-bg/40">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-heading text-4xl md:text-5xl text-text-main mb-4">
          Psicóloga em Niterói
        </h1>
        <p class="text-text-main/70 text-lg max-w-2xl mx-auto mb-8">
          Elisa Fontes atende pacientes de todos os bairros de Niterói. Consultório presencial em
          <a href="/area-atendida/sao-francisco" class="text-accent underline hover:opacity-80">São Francisco</a>
          e atendimento online para todo o Brasil.
        </p>
        <a
          href="https://wa.me/5521987449887?text=Ol%C3%A1%2C%20Elisa!%20Vim%20pelo%20seu%20site%20e%20gostaria%20de%20agendar%20uma%20sess%C3%A3o."
          class="inline-block bg-accent text-white px-8 py-3 rounded-sm font-medium hover:bg-accent/90 transition-colors"
        >
          Agendar consulta
        </a>
      </div>
    </section>

    <!-- Office Info -->
    <section class="py-12 px-6 md:px-12 lg:px-20 border-b border-stone-200">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl text-text-main mb-6">Onde fica o consultório?</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-lg border border-stone-100 shadow-sm">
            <h3 class="font-medium text-text-main mb-2">Consultório São Francisco</h3>
            <p class="text-text-main/70 text-sm mb-1">Rua Rui Barbosa, 29 - Sala 213</p>
            <p class="text-text-main/70 text-sm mb-1">São Francisco, Niterói - RJ</p>
            <p class="text-text-main/70 text-sm mb-3">Segunda a sábado, 10h às 20h</p>
            <a href="/area-atendida/sao-francisco" class="text-accent text-sm underline hover:opacity-80">
              Ver página do bairro →
            </a>
          </div>
          <div class="bg-white p-6 rounded-lg border border-stone-100 shadow-sm">
            <h3 class="font-medium text-text-main mb-2">Atendimento Online</h3>
            <p class="text-text-main/70 text-sm mb-3">
              Para quem prefere flexibilidade de horário e localização. Atende pacientes de todo o Brasil pela plataforma de sua escolha.
            </p>
            <a href="/contato" class="text-accent text-sm underline hover:opacity-80">
              Falar com Elisa →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Neighborhoods by Region -->
    <section class="py-12 px-6 md:px-12 lg:px-20">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl text-text-main mb-8">Bairros atendidos em Niterói</h2>

        {regioes.map((regiao) => (
          <div class="mb-10">
            <h3 class="text-sm font-semibold uppercase tracking-widest text-text-main/50 mb-4 border-b border-stone-200 pb-2">
              {regiao}
            </h3>
            <div class="flex flex-wrap gap-3">
              {getBairrosByRegiao(regiao).map((bairro) => (
                <a
                  href={`/area-atendida/${bairro.slug}`}
                  class="px-4 py-2 bg-white border border-stone-200 rounded-sm text-text-main text-sm hover:border-accent hover:text-accent transition-colors"
                >
                  {bairro.name}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- About CTA -->
    <section class="py-12 px-6 md:px-12 lg:px-20 bg-card-bg/40 border-t border-stone-200">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-heading text-2xl text-text-main mb-4">
          Sobre Elisa Fontes
        </h2>
        <p class="text-text-main/70 mb-6 max-w-2xl mx-auto">
          38 anos de experiência em psicanálise. Atende adultos e adolescentes (a partir de 16 anos) com questões de ansiedade, autoestima, relacionamentos e desenvolvimento pessoal.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/sobre" class="text-accent underline hover:opacity-80 font-medium">Conheça Elisa →</a>
          <a href="/blog" class="text-accent underline hover:opacity-80 font-medium">Leia o blog →</a>
          <a href="/contato" class="text-accent underline hover:opacity-80 font-medium">Entre em contato →</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
