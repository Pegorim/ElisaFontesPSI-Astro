---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { bairros, getBairrosByRegiao } from '../../data/bairros';
import type { Bairro } from '../../data/bairros';

export function getStaticPaths() {
  return bairros.map((bairro) => ({
    params: { bairro: bairro.slug },
    props: { bairro },
  }));
}

const { bairro } = Astro.props as { bairro: Bairro };
const nearbyBairros = getBairrosByRegiao(bairro.regiao).filter((b) => b.slug !== bairro.slug);

const isSaoFrancisco = bairro.slug === "sao-francisco";

const locationSchema = {
  "@context": "https://schema.org",
  "@type": ["Psychologist", "LocalBusiness"],
  "name": "Elisa Fontes - Psicóloga em Niterói",
  "description": `Psicóloga clínica com 38 anos de experiência atendendo pacientes de ${bairro.name}, Niterói. Consultas presenciais e online.`,
  "url": `https://elisafontes.com.br/areas-atendidas/${bairro.slug}`,
  "telephone": "+55-21-98744-9887",
  "email": "psi.elisafontes@gmail.com",
  "image": "https://elisafontes.com.br/images/profile.jpg",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Rua Rui Barbosa, 29 - Sala 213",
    "addressLocality": "São Francisco",
    "addressRegion": "Niterói, RJ",
    "postalCode": "24360-400",
    "addressCountry": "BR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -22.8833,
    "longitude": -43.1036
  },
  "openingHours": ["Mo-Sa 10:00-20:00"],
  "priceRange": "$$",
  "areaServed": {
    "@type": "Place",
    "name": `${bairro.name}, Niterói, RJ`
  },
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "credentialCategory": "Professional License",
    "name": "CRP 05/62794"
  }
};
---

<Layout
  title={`Psicóloga em ${bairro.name}, Niterói | Elisa Fontes`}
  description={`Psicóloga em ${bairro.name}, Niterói. Elisa Fontes oferece atendimento psicanalítico presencial e online. 38 anos de experiência. CRP 05/62794.`}
  schema={locationSchema}
>
  <Header />

  <main class="bg-primary-bg">

    <!-- Breadcrumb -->
    <nav class="px-6 md:px-12 lg:px-20 py-4 text-sm text-text-main/60">
      <a href="/" class="hover:text-accent transition-colors">Início</a>
      <span class="mx-2">›</span>
      <a href="/areas-atendidas" class="hover:text-accent transition-colors">Área Atendida</a>
      <span class="mx-2">›</span>
      <span class="text-text-main">{bairro.name}</span>
    </nav>

    <!-- Hero -->
    <section class="py-12 md:py-16 px-6 md:px-12 lg:px-20 bg-card-bg/40">
      <div class="max-w-4xl mx-auto">
        <p class="text-accent text-sm font-medium uppercase tracking-wider mb-3">{bairro.regiao} · Niterói, RJ</p>
        <h1 class="font-heading text-4xl md:text-5xl text-text-main mb-4">
          Psicóloga em {bairro.name}
        </h1>
        <p class="text-text-main/70 text-lg max-w-2xl mb-8">
          Elisa Fontes atende pacientes de {bairro.name} com acompanhamento psicanalítico presencial e online.
          38 anos de experiência cuidando de pessoas. CRP 05/62794.
        </p>
        <a
          href="https://wa.me/5521987449887?text=Ol%C3%A1%2C%20Elisa!%20Vim%20pelo%20seu%20site%20e%20gostaria%20de%20agendar%20uma%20sess%C3%A3o."
          class="inline-block bg-accent text-white px-8 py-3 rounded-sm font-medium hover:bg-accent/90 transition-colors"
        >
          Agendar consulta
        </a>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12 px-6 md:px-12 lg:px-20">
      <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-10">

        <!-- Article -->
        <article class="md:col-span-2 prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-text-main prose-p:text-text-main/80 prose-a:text-accent prose-p:mb-8 prose-headings:mt-10">

          <h2>Atendimento psicológico para quem mora em {bairro.name}</h2>
          <p>
            Se você mora em {bairro.name} e está buscando apoio psicológico profissional, Elisa Fontes oferece
            atendimento presencial e online com abordagem psicanalítica.
            Com 38 anos de experiência, Elisa acolhe adultos e adolescentes (a partir de 16 anos) que enfrentam
            questões como ansiedade, autoestima, dificuldades nos relacionamentos, e outros desafios da vida cotidiana.
          </p>

          <h2>Como funciona o atendimento</h2>
          <p>
            A psicanálise é uma abordagem terapêutica que vai além dos sintomas: ela busca compreender as raízes
            dos padrões emocionais e comportamentais, proporcionando um autoconhecimento profundo e duradouro.
            As sessões acontecem semanalmente e, ao longo do processo, você constrói uma relação de confiança
            com Elisa para explorar o que mais importa na sua vida.
          </p>
          <p>
            Elisa atende pacientes de {bairro.name} de duas formas:
          </p>
          <ul>
            <li>
              <strong>Presencial</strong> — no consultório em São Francisco, Niterói (Rua Rui Barbosa, 29 - Sala 213),
              de segunda a sábado, das 10h às 20h.
              {!isSaoFrancisco && ` ${bairro.name} tem fácil acesso a São Francisco via transporte público e carro.`}
            </li>
            <li>
              <strong>Online</strong> — atendimento por videochamada, com toda a flexibilidade de horário e localização.
              Ideal para quem tem rotina intensa ou prefere o conforto de casa.
            </li>
          </ul>

          <h2>Principais temas atendidos</h2>
          <ul>
            <li>Ansiedade e transtornos de ansiedade</li>
            <li>Depressão e falta de motivação</li>
            <li>Autoestima e autoconhecimento</li>
            <li>Dificuldades nos relacionamentos</li>
            <li>Crises de pânico</li>
            <li>Luto e perdas</li>
            <li>Questões de identidade e sentido de vida</li>
          </ul>

          <h2>Por que escolher Elisa Fontes?</h2>
          <p>
            Elisa tem formação pela Universidade Estácio de Sá e registro no Conselho Regional de Psicologia
            (CRP 05/62794). Sua abordagem em psicanálise, aliada a décadas de experiência clínica, oferece
            um espaço seguro, acolhedor e sem julgamentos para você trabalhar o que precisar.
          </p>

          <h2>Como agendar uma consulta</h2>
          <p>
            O agendamento é feito pelo WhatsApp. Entre em contato, apresente-se brevemente e combine o melhor
            dia e horário para você. A primeira sessão é uma conversa inicial para vocês se conhecerem e
            avaliar se a terapia faz sentido para o momento que você vive.
          </p>
        </article>

        <!-- Sidebar -->
        <aside class="md:col-span-1 space-y-6">

          <!-- Contact Card -->
          <div class="bg-white p-6 rounded-lg border border-stone-100 shadow-sm">
            <h3 class="font-heading text-lg text-text-main mb-4">Fale com Elisa</h3>
            <p class="text-sm text-text-main/70 mb-4">Atendendo pacientes de {bairro.name} e toda Niterói.</p>
            <a
              href="https://wa.me/5521987449887?text=Ol%C3%A1%2C%20Elisa!%20Vim%20pelo%20seu%20site%20e%20gostaria%20de%20agendar%20uma%20sess%C3%A3o."
              class="block text-center bg-[#25D366] text-white px-4 py-3 rounded-sm font-medium hover:bg-[#1ebe5b] transition-colors text-sm mb-3"
            >
              Agendar pelo WhatsApp
            </a>
            <a href="/contato" class="block text-center border border-accent text-accent px-4 py-3 rounded-sm font-medium hover:bg-accent/5 transition-colors text-sm">
              Ver formas de contato
            </a>
          </div>

          <!-- Office Info -->
          <div class="bg-white p-6 rounded-lg border border-stone-100 shadow-sm">
            <h3 class="font-medium text-text-main mb-3">Consultório São Francisco</h3>
            <p class="text-sm text-text-main/70 mb-1">Rua Rui Barbosa, 29 - Sala 213</p>
            <p class="text-sm text-text-main/70 mb-1">São Francisco, Niterói - RJ</p>
            <p class="text-sm text-text-main/70">Seg a Sáb, 10h–20h</p>
          </div>

          <!-- Quick Links -->
          <div class="bg-white p-6 rounded-lg border border-stone-100 shadow-sm">
            <h3 class="font-medium text-text-main mb-3">Saiba mais</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/sobre" class="text-accent hover:opacity-80 underline">Sobre Elisa Fontes</a></li>
              <li><a href="/blog/ansiedade-psicoterapia" class="text-accent hover:opacity-80 underline">Como a terapia funciona</a></li>
              <li><a href="/blog/psicologo-niteroi" class="text-accent hover:opacity-80 underline">Como escolher um psicólogo</a></li>
              <li><a href="/blog" class="text-accent hover:opacity-80 underline">Blog sobre saúde mental</a></li>
            </ul>
          </div>

        </aside>
      </div>
    </section>

    <!-- Nearby Neighborhoods -->
    {nearbyBairros.length > 0 && (
      <section class="py-10 px-6 md:px-12 lg:px-20 border-t border-stone-200">
        <div class="max-w-4xl mx-auto">
          <h2 class="font-heading text-xl text-text-main mb-5">
            Outros bairros atendidos na {bairro.regiao}
          </h2>
          <div class="flex flex-wrap gap-3">
            {nearbyBairros.map((b) => (
              <a
                href={`/areas-atendidas/${b.slug}`}
                class="px-4 py-2 bg-white border border-stone-200 rounded-sm text-text-main text-sm hover:border-accent hover:text-accent transition-colors"
              >
                {b.name}
              </a>
            ))}
          </div>
          <p class="mt-4 text-sm text-text-main/60">
            <a href="/areas-atendidas" class="text-accent underline hover:opacity-80">Ver todos os bairros →</a>
          </p>
        </div>
      </section>
    )}

  </main>

  <Footer />
</Layout>
