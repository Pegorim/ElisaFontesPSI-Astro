---
const testimonials = [
  {
    text: 'Sou paciente da Elisa há mais de dois anos, e as consultas foram sempre pontuais e com ótimos resultados',
    author: 'Jussara',
    position: 'left'
  },
  {
    text: 'Profissional muito competente, pontual e tem feito um trabalho incrível com o qual já senti muita diferença na minha vida',
    author: 'Lívia',
    position: 'right'
  },
  {
    text: 'Sensacional, me ajuda demais em todas as questões que preciso e me mostra muita clareza e confiança',
    author: 'Rafael',
    position: 'left'
  }
];
---

<section class="bg-primary-bg px-6 py-12 md:px-12 lg:px-20">
  <div class="mx-auto max-w-4xl space-y-8">
    {testimonials.map((t) => (
      <div class:list={[
        'flex items-start gap-4',
        t.position === 'right' ? 'flex-row-reverse' : ''
      ]}>
        <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full bg-card-bg font-semibold text-text-main shadow-sm">
          {t.author.charAt(0)}
        </div>

        <div class="max-w-xl rounded-2xl bg-white px-6 py-4 shadow-sm ring-1 ring-stone-200">
          <p class="text-text-main leading-7">
            “{t.text}” <span class="ml-2 font-medium">{t.author}</span>
          </p>
        </div>
      </div>
    ))}
  </div>
</section>

<hr class="mx-6 border-t border-stone-300 md:mx-12 lg:mx-20" />
